#include <iostream>
#include <string>
#include <algorithm>
using namespace std;

int main() {
    string s;
    cin >> s;

    sort(s.begin(), s.end());

    for (int i = 0; i < s.length(); i++) {
        if (s[i] != '+')
            cout << s[i];

        if (i != s.length() - 1 && s[i] != '+')
            cout << "+";
    }

    return 0;
}
