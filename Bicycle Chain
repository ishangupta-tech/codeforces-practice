#include <iostream>
using namespace std;

int main() {
    int n, m;
    cin >> n;

    int a[55], b[55];

    for (int i = 0; i < n; i++)
        cin >> a[i];

    cin >> m;

    for (int i = 0; i < m; i++)
        cin >> b[i];

    int mx = 0, cnt = 0;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < m; j++) {
            if (b[j] % a[i] == 0) {
                int ratio = b[j] / a[i];
                if (ratio > mx) {
                    mx = ratio;
                    cnt = 1;
                } else if (ratio == mx) {
                    cnt++;
                }
            }
        }
    }

    cout << cnt;

    return 0;
}
