#include <iostream>
#include <string>
#include <set>
using namespace std;

int main() {
    string s;
    cin >> s;

    set<char> letters;

    for (int i = 0; i < s.length(); i++) {
        letters.insert(s[i]);
    }

    if (letters.size() % 2 == 0)
        cout << "CHAT WITH HER!";
    else
        cout << "IGNORE HIM!";

    return 0;
}
