#include <iostream>
#include <algorithm>
#include <string>
using namespace std;

int main() {
    int n;
    string s;
    cin >> n >> s;

    string a = s.substr(0, n);
    string b = s.substr(n, n);

    sort(a.begin(), a.end());
    sort(b.begin(), b.end());

    bool greater = true, smaller = true;

    for (int i = 0; i < n; i++) {
        if (a[i] <= b[i]) greater = false;
        if (a[i] >= b[i]) smaller = false;
    }

    if (greater || smaller)
        cout << "YES";
    else
        cout << "NO";

    return 0;
}
