#include <iostream>
#include <vector>
#include <map>
using namespace std;

int main() {
    int n;
    cin >> n;

    map<int, vector<int>> mp;

    for (int i = 1; i <= n; i++) {
        int x;
        cin >> x;
        mp[x].push_back(i);
    }

    vector<pair<int, int>> ans;

    for (auto it : mp) {
        vector<int> &v = it.second;

        if (v.size() == 1) {
            ans.push_back({it.first, 0});
        } else {
            int d = v[1] - v[0];
            bool ok = true;

            for (int i = 2; i < v.size(); i++) {
                if (v[i] - v[i - 1] != d) {
                    ok = false;
                    break;
                }
            }

            if (ok) {
                ans.push_back({it.first, d});
            }
        }
    }

    cout << ans.size() << '\n';

    for (auto x : ans) {
        cout << x.first << " " << x.second << '\n';
    }

    return 0;
}
