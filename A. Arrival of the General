#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int a[100];
    int max = -1, min = 101;
    int maxPos = 0, minPos = 0;

    for (int i = 0; i < n; i++) {
        cin >> a[i];

        if (a[i] > max) {
            max = a[i];
            maxPos = i;
        }

        if (a[i] <= min) {
            min = a[i];
            minPos = i;
        }
    }

    int moves = maxPos + (n - 1 - minPos);

    if (maxPos > minPos)
        moves--;

    cout << moves;

    return 0;
}
