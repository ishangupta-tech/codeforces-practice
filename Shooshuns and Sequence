#include <iostream>
using namespace std;

int main() {
    int n, k;
    cin >> n >> k;

    int a[105];

    for (int i = 1; i <= n; i++) {
        cin >> a[i];
    }

    for (int i = k; i <= n; i++) {
        if (a[i] != a[k]) {
            cout << -1;
            return 0;
        }
    }

    int ans = 0;

    for (int i = k - 1; i >= 1; i--) {
        if (a[i] != a[k]) {
            ans = i;
            break;
        }
    }

    cout << ans;

    return 0;
}
