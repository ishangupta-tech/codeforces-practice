#include <iostream>
#include <string>
#include <vector>
using namespace std;

int main() {
    string a, b;
    cin >> a >> b;

    vector<int> diff;

    for (int i = 0; i < a.size(); i++) {
        if (a[i] != b[i]) {
            diff.push_back(i);
        }
    }

    if (diff.size() != 2) {
        cout << "NO";
        return 0;
    }

    swap(a[diff[0]], a[diff[1]]);

    if (a == b)
        cout << "YES";
    else
        cout << "NO";

    return 0;
}
