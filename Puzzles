#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    int a[55];

    for (int i = 0; i < m; i++)
        cin >> a[i];

    sort(a, a + m);

    int ans = 1000000;

    for (int i = 0; i + n - 1 < m; i++) {
        ans = min(ans, a[i + n - 1] - a[i]);
    }

    cout << ans;

    return 0;
}
