#include <iostream>
#include <string>
#include <cmath>
using namespace std;

int main() {
    int t, sx, sy, ex, ey;
    string s;

    cin >> t;
    cin >> sx >> sy >> ex >> ey;
    cin >> s;

    for (int i = 0; i < t; i++) {
        if (s[i] == 'N' && sy < ey) sy++;
        else if (s[i] == 'S' && sy > ey) sy--;
        else if (s[i] == 'E' && sx < ex) sx++;
        else if (s[i] == 'W' && sx > ex) sx--;

        if (sx == ex && sy == ey) {
            cout << i + 1;
            return 0;
        }
    }

    cout << -1;
    return 0;
}
