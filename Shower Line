#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int g[5][5];

    for (int i = 0; i < 5; i++) {
        for (int j = 0; j < 5; j++) {
            cin >> g[i][j];
        }
    }

    int p[] = {0, 1, 2, 3, 4};
    int ans = 0;

    do {
        int sum = 0;

        sum += g[p[0]][p[1]] + g[p[1]][p[0]];
        sum += g[p[2]][p[3]] + g[p[3]][p[2]];
        sum += g[p[1]][p[2]] + g[p[2]][p[1]];
        sum += g[p[3]][p[4]] + g[p[4]][p[3]];
        sum += g[p[2]][p[3]] + g[p[3]][p[2]];
        sum += g[p[3]][p[4]] + g[p[4]][p[3]];

        ans = max(ans, sum);

    } while (next_permutation(p, p + 5));

    cout << ans;

    return 0;
}
