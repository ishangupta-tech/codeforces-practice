#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int x[200], y[200];

    for (int i = 0; i < n; i++) {
        cin >> x[i] >> y[i];
    }

    int count = 0;

    for (int i = 0; i < n; i++) {
        bool left = false, right = false, up = false, down = false;

        for (int j = 0; j < n; j++) {
            if (x[j] < x[i] && y[j] == y[i])
                left = true;
            if (x[j] > x[i] && y[j] == y[i])
                right = true;
            if (x[j] == x[i] && y[j] > y[i])
                up = true;
            if (x[j] == x[i] && y[j] < y[i])
                down = true;
        }

        if (left && right && up && down)
            count++;
    }

    cout << count;

    return 0;
}
