#include <iostream>
#include <algorithm>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    int a[105], b[105];

    for (int i = 0; i < m; i++) {
        cin >> a[i];
        b[i] = a[i];
    }

    int mx = 0, mn = 0;

    for (int i = 0; i < n; i++) {
        int idx = max_element(a, a + m) - a;
        mx += a[idx];
        a[idx]--;
    }

    for (int i = 0; i < n; i++) {
        int idx = min_element(b, b + m) - b;

        while (b[idx] == 0)
            idx = min_element(b, b + m) - b;

        mn += b[idx];
        b[idx]--;
    }

    cout << mx << " " << mn;

    return 0;
}
