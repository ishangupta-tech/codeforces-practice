#include <iostream>
using namespace std;

int main()
{
    int n, m;
    cin >> n >> m;

    for (int x = n + 1; x <= 100; x++)
    {
        bool isPrime = true;

        // Check whether x is prime.
        for (int i = 2; i < x; i++)
        {
            if (x % i == 0)
            {
                isPrime = false;
                break;
            }
        }

        // If x is prime, compare it with m.
        if (isPrime)
        {
            if (x == m)
            {
                cout << "YES";
            }
            else
            {
                cout << "NO";
            }

            // We only care about the first prime after n.
            break;
        }
    }

    return 0;
}
