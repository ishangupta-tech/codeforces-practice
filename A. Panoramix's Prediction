#include <iostream>
using namespace std;

bool isPrime(int x) {
    for (int i = 2; i * i <= x; i++) {
        if (x % i == 0)
            return false;
    }
    return true;
}

int main() {
    int n, m;
    cin >> n >> m;

    int nextPrime;

    for (int i = n + 1;; i++) {
        if (isPrime(i)) {
            nextPrime = i;
            break;
        }
    }

    if (nextPrime == m)
        cout << "YES";
    else
        cout << "NO";

    return 0;
}
