#include <iostream>
#include <string>
using namespace std;

int main() {
    int n, x, cnt5 = 0, cnt0 = 0;
    cin >> n;

    for (int i = 0; i < n; i++) {
        cin >> x;
        if (x == 5) cnt5++;
        else cnt0++;
    }

    if (cnt0 == 0) {
        cout << -1;
        return 0;
    }

    cnt5 = (cnt5 / 9) * 9;

    if (cnt5 == 0) {
        cout << 0;
        return 0;
    }

    for (int i = 0; i < cnt5; i++) cout << 5;
    for (int i = 0; i < cnt0; i++) cout << 0;

    return 0;
}
