#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int ans = 0;

    for (int a = 1; a <= n; a++) {
        for (int b = a; b <= n; b++) {
            int c2 = a * a + b * b;

            for (int c = b; c <= n; c++) {
                if (c * c == c2) {
                    ans++;
                    break;
                }
            }
        }
    }

    cout << ans;

    return 0;
}
