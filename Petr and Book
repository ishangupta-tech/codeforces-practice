#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int a[7];

    for (int i = 0; i < 7; i++) {
        cin >> a[i];
    }

    int day = 0;

    while (n > 0) {
        n -= a[day];
        if (n <= 0) {
            cout << day + 1;
            return 0;
        }
        day = (day + 1) % 7;
    }

    return 0;
}
