#include <iostream>
#include <vector>
using namespace std;

int main() {
    int y, k, n;
    cin >> y >> k >> n;

    vector<int> ans;

    for (int x = 1; x + y <= n; x++) {
        if ((x + y) % k == 0) {
            ans.push_back(x);
        }
    }

    if (ans.empty()) {
        cout << -1;
    } else {
        for (int x : ans) {
            cout << x << " ";
        }
    }

    return 0;
}
