#include <iostream>
using namespace std;

const int MOD = 1073741824;

int divisors(int x) {
    int cnt = 0;
    for (int i = 1; i * i <= x; i++) {
        if (x % i == 0) {
            cnt++;
            if (i != x / i)
                cnt++;
        }
    }
    return cnt;
}

int main() {
    int a, b, c;
    cin >> a >> b >> c;

    long long ans = 0;

    for (int i = 1; i <= a; i++) {
        for (int j = 1; j <= b; j++) {
            for (int k = 1; k <= c; k++) {
                ans += divisors(i * j * k);
                ans %= MOD;
            }
        }
    }

    cout << ans % MOD;

    return 0;
}
