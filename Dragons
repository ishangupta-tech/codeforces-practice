#include <iostream>
#include <algorithm>
using namespace std;

struct Dragon {
    int strength, bonus;
};

bool cmp(Dragon a, Dragon b) {
    return a.strength < b.strength;
}

int main() {
    int s, n;
    cin >> s >> n;

    Dragon d[1005];

    for (int i = 0; i < n; i++)
        cin >> d[i].strength >> d[i].bonus;

    sort(d, d + n, cmp);

    for (int i = 0; i < n; i++) {
        if (s <= d[i].strength) {
            cout << "NO";
            return 0;
        }
        s += d[i].bonus;
    }

    cout << "YES";

    return 0;
}
