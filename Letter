#include <iostream>
#include <string>
using namespace std;

int main() {
    string s1, s2, s3;
    getline(cin, s1);
    getline(cin, s2);
    getline(cin, s3);

    int cnt[256] = {0};

    for (char c : s1) cnt[c]++;
    for (char c : s2) cnt[c]++;
    for (char c : s3) cnt[c]--;

    for (int i = 0; i < 256; i++) {
        if (cnt[i] != 0) {
            cout << "NO";
            return 0;
        }
    }

    cout << "YES";
    return 0;
}
