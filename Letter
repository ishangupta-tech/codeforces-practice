#include <iostream>
#include <string>
using namespace std;

int main() {
    string s, t, all = "";
    getline(cin, s);
    getline(cin, t);

    all = s + t;

    int cnt1[256] = {0};
    int cnt2[256] = {0};

    string name, pile;
    getline(cin, name);
    getline(cin, pile);

    for (char c : name)
        if (c != ' ')
            cnt1[c]++;

    for (char c : pile)
        if (c != ' ')
            cnt2[c]++;

    for (int i = 0; i < 256; i++) {
        if (cnt1[i] != cnt2[i]) {
            cout << "NO";
            return 0;
        }
    }

    cout << "YES";

    return 0;
}
