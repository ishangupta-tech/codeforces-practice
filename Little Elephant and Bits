#include <iostream>
#include <string>
using namespace std;

int main() {
    string s;
    cin >> s;

    bool removed = false;

    for (int i = 0; i < s.size(); i++) {
        if (s[i] == '0') {
            s.erase(i, 1);
            removed = true;
            break;
        }
    }

    if (!removed) {
        s.erase(s.size() - 1, 1);
    }

    cout << s;

    return 0;
}
