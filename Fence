#include <iostream>
using namespace std;

int main() {
    int n, k;
    cin >> n >> k;

    int a[150005];

    for (int i = 0; i < n; i++)
        cin >> a[i];

    int sum = 0;
    for (int i = 0; i < k; i++)
        sum += a[i];

    int mn = sum;
    int pos = 1;

    for (int i = k; i < n; i++) {
        sum += a[i];
        sum -= a[i - k];

        if (sum < mn) {
            mn = sum;
            pos = i - k + 2;
        }
    }

    cout << pos;

    return 0;
}
