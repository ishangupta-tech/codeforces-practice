#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int score;
    cin >> score;

    int best = score;
    int worst = score;
    int count = 0;

    for (int i = 1; i < n; i++) {
        cin >> score;

        if (score > best) {
            best = score;
            count++;
        }
        else if (score < worst) {
            worst = score;
            count++;
        }
    }

    cout << count;

    return 0;
}
