#include <iostream>
#include <string>
using namespace std;

int main() {
    int k;
    string s;
    cin >> k >> s;

    int cnt[26] = {0};

    for (char c : s)
        cnt[c - 'a']++;

    for (int i = 0; i < 26; i++) {
        if (cnt[i] % k != 0) {
            cout << -1;
            return 0;
        }
    }

    string t = "";
    for (int i = 0; i < 26; i++) {
        t.append(cnt[i] / k, char('a' + i));
    }

    for (int i = 0; i < k; i++)
        cout << t;

    return 0;
}
