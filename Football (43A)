#include <iostream>
#include <map>
#include <string>
using namespace std;

int main() {
    int n;
    cin >> n;

    map<string, int> mp;
    string s;

    for (int i = 0; i < n; i++) {
        cin >> s;
        mp[s]++;
    }

    string ans;
    int mx = 0;

    for (auto x : mp) {
        if (x.second > mx) {
            mx = x.second;
            ans = x.first;
        }
    }

    cout << ans;
    return 0;
}
