#include <iostream>
#include <cmath>
using namespace std;

int main() {
    int n;
    cin >> n;

    int h[100];

    for (int i = 0; i < n; i++) {
        cin >> h[i];
    }

    int minDiff = abs(h[0] - h[n - 1]);
    int first = n;
    int second = 1;

    for (int i = 0; i < n - 1; i++) {
        if (abs(h[i] - h[i + 1]) < minDiff) {
            minDiff = abs(h[i] - h[i + 1]);
            first = i + 1;
            second = i + 2;
        }
    }

    cout << first << " " << second;

    return 0;
}
