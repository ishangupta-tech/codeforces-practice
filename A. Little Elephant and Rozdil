#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int a[100000];

    int minTime = 1000000000;
    int index = -1;
    int count = 0;

    for (int i = 0; i < n; i++) {
        cin >> a[i];

        if (a[i] < minTime) {
            minTime = a[i];
            index = i + 1;
            count = 1;
        }
        else if (a[i] == minTime) {
            count++;
        }
    }

    if (count > 1)
        cout << "Still Rozdil";
    else
        cout << index;

    return 0;
}
