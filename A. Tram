#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int passengers = 0;
    int maxPassengers = 0;

    for (int i = 0; i < n; i++) {
        int a, b;
        cin >> a >> b;

        passengers -= a;
        passengers += b;

        if (passengers > maxPassengers)
            maxPassengers = passengers;
    }

    cout << maxPassengers;

    return 0;
}
